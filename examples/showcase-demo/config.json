        "首版 | 2025-10",
        "模板库 | 2026-Q1",
        "Effects | 2026-Q2"
      ]
    },
    {
      "template": "arch-diagram",
      "title": "arch-diagram",
      "bullets": [
        "config.json | 声明式",
        "rf generate | CLI",
        "engine-chrome | 渲染",
        "ffmpeg | 混流",
        "mp4 | 成片"
      ]
    },
    {
      "template": "flowchart",
      "title": "flowchart",
      "bullets": [
        "构建通过?",
        "yes | 打包发布",
        "no | 回滚分支"
      ],
      "transition": "flash-white",
      "transitionDurationMs": 300
    },
    {
      "template": "split-compare",
      "title": "split-compare",
      "subtitle": "一图胜千言",
      "extras": {
        "leftTag": "BEFORE",
        "leftTitle": "手写 HTML + GSAP",
        "leftBody": "<h1>Title</h1>\ngsap.timeline()\n  .from(h1, { y: 40 })\n  .to(h1, { opacity: 0 })\nffmpeg -i a.html ...",
        "rightTag": "AFTER",
        "rightTitle": "rf generate",
        "rightBody": "{\n  \"slides\": [{\n    \"template\": \"hero-fade-up\",\n    \"title\": \"Title\"\n  }]\n}\n$ rf generate config.json"
      }
    },
    {
      "template": "code-block",
      "title": "code-block",
      "subtitle": "app.ts",
      "bullets": [
        "// dark-mode macOS-style window",
        "import { renderChrome } from '@reelforge/engine-chrome';",
        "",
        "const mp4 = await renderChrome({",
        "  project,",
        "  outputPath: './showcase.mp4',",
        "});",
        "",
        "return mp4;"
      ],
      "transition": "wipe-sweep",
      "transitionDurationMs": 400
    },
